APP_ENV=development

KV_NAMESPACE_ID=
KV_USER_ID=
CLOUDFLARE_API_TOKEN=

PASETO_SECRET_KEY=
PASETO_PUBLIC_KEY=

PORT=1323

DATABASE_URL=

ENCRYPTION_KEY=

# Auth service (GAS)
GAS_SERVICE_URL=gas.quddus.my:50052

# Schedule cache (GEI). Optional: if GEI_SERVICE_URL is unset the cache is
# disabled and schedules are scraped in full every request. GEI_ADMIN_KEY must
# match GEI's ADMIN_KEY; it guards cache writes.
GEI_SERVICE_URL=gei.quddus.my:50053
GEI_ADMIN_KEY=

# i-Ma'luum egress relay. IIUM blocks our datacenter IP on /MyAcademic/*, so
# route i-Ma'luum requests through a URL-rewriting relay (e.g. a Cloudflare
# Worker) whose IP isn't blocked. The target URL is appended to the prefix.
# Accepts a comma-separated list; requests are round-robined across them.
# Optional: unset = scrape direct. Example:
# IMALUUM_PROXY_PREFIX=https://proxy.example.workers.dev/------,https://proxy2.example.workers.dev/------
IMALUUM_PROXY_PREFIX=
